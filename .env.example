# wisp-ops-center örnek ortam değişkenleri
# Bu dosyayı .env olarak kopyalayın ve yerel değerlerinizi doldurun.
# ASLA gerçek parolaları .env.example'a yazmayın.

# --- Genel ---
WISP_ENV=development
WISP_HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=text

# Production'da zorunlu kullanın. Boş bırakırsanız API auth kapalıdır
# (sadece yerel geliştirme için kabul edilebilir; production değil).
WISP_API_TOKEN=

# --- PostgreSQL ---
# Faz 2 itibarıyla envanter API'leri için zorunludur.
WISP_DATABASE_URL=postgres://wispops_app:CHANGE_ME@localhost:5432/wispops?sslmode=disable
DATABASE_MAX_OPEN_CONNS=10
DATABASE_MAX_IDLE_CONNS=5

# --- Vault ---
# 32 baytlık AES-256 anahtarı. Üretmek için:
#   openssl rand -base64 32
# ASLA gerçek anahtarı .env.example'a, depoya, log'a, cevaba koymayın.
WISP_VAULT_KEY=

# --- Redis (Asynq, Faz 5+) ---
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0

# --- Web ---
NEXT_PUBLIC_API_BASE=http://localhost:8080
NEXT_PUBLIC_API_TOKEN=

# --- MikroTik Dude (Faz 8 — Network Inventory Discovery) ---
# SSH üzerinden MikroTik Dude / RouterOS cihazına bağlanıp envanter taraması.
# Sadece read-only discovery; cihaza yazma yapılmaz.
# ŞİFRE ASLA .env.example'a, repo'ya, log'a, çıkışlara yazılmaz.
MIKROTIK_DUDE_HOST=194.15.45.62
MIKROTIK_DUDE_PORT=22
MIKROTIK_DUDE_USERNAME=bariss
MIKROTIK_DUDE_PASSWORD=
MIKROTIK_DUDE_TIMEOUT_MS=10000
# insecure_ignore | trust_on_first_use | pinned
MIKROTIK_DUDE_HOST_KEY_POLICY=trust_on_first_use
# pinned politikası kullanılırsa sha256 fingerprint (örn. SHA256:abcd...)
MIKROTIK_DUDE_HOST_KEY_FINGERPRINT=
